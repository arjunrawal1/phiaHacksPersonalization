APP_NAME=phia-backend
ENVIRONMENT=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

CORS_ORIGINS=["*"]

DATA_DIR=./data
SQLITE_PATH=./data/phia.db
MEDIA_DIR=./data/media
PUBLIC_MEDIA_BASE_URL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

SERPAPI_KEY=
REPLICATE_API_TOKEN=

RECENT_LIMIT=50
PHOTO_CONCURRENCY=10
LOOKUP_CONCURRENCY=5
ONLINE_FACE_IMAGE_LIMIT=8
AUTO_FACE_PICK_THRESHOLD=0.75
AUTO_FACE_PICK_MARGIN=0.12
AUTO_FACE_PICK_ALIGNMENT_FLOOR=0.5
